{
  "packages" : {
    "vscode" : {
      "src" : "https://github.com/microsoft/vscode/archive/refs/heads/main.zip",
      "links" : {
        "nt" : "https://code.visualstudio.com/sha/download?build=stable&os=cli-win32-x64",
        "darwin" : "https://code.visualstudio.com/sha/download?build=stable&os=cli-darwin-arm64",
        "posix" : "https://code.visualstudio.com/sha/download?build=stable&os=cli-alpine-x64",
        "save-as" : {
          "nt" : "code.exe",
          "darwin" : "code.zip",
          "posix" : "code.tar.gz"
        }
      },
      "setup" : {
        "nt" : ["code.exe"],
        "darwin" : ["tar -xf code.zip", "./code"],
        "posix" : ["tar -xf vscode", "./code"]
      },
      "run" : {
        "nt" : ["code.exe"],
        "darwin" : ["./code"],
        "posix" : ["./code"]
      },
      "show" : [
        "Successfuly installed dostool!",
        "Usage: dostool <args>",
        "Distributed under GPL 3.0; Author - i4ego"
      ]
    },
    "python" : {
      "src" : "https://github.com/python/cpython/archive/refs/heads/3.12.zip",
      "links" : {
        "nt" : "https://www.python.org/ftp/python/3.12.2/python-3.12.2.exe",
        "darwin" : "https://www.python.org/ftp/python/3.12.2/python-3.12.2-macos11.pkg",
        "posix" : null,
        "save-as" : {
          "nt" : "python-install.exe",
          "darwin" : "python-install.pkg",
          "posix" : null
        }
      },
      "setup" : {
        "nt" : ["python-install.exe"],
        "darwin" : ["sudo installer -pkg python-install.pkg -target /"],
        "posix" : []
      },
      "run" : {
        "nt" : ["python3"],
        "darwin" : ["python3"],
        "posix" : null
      },
      "show" : [
        "Successfuly installed Python!",
        "License - https://github.com/python/cpython/raw/refs/heads/3.12/LICENSE"
      ]
    },
    "libresprite" : {
      "src" : "https://github.com/libresprite/libresprite/archive/refs/heads/stable-1.x.zip",
      "links" : {
        "nt" : "https://github.com/LibreSprite/LibreSprite/releases/download/v1.0/LibreSprite-Windows-x86_32.zip",
        "darwin" : "https://github.com/LibreSprite/LibreSprite/releases/download/v1.0/LibreSprite-macos-x86_64.zip",
        "posix" : null,
        "save-as" : {
          "nt" : "libresprite.zip",
          "darwin" : "libresprite.zip",
          "posix" : null
        }
      },
      "setup" : {
        "nt" : ["tar -xf libresprite.zip", "libresprite.exe"],
        "darwin" : ["tar -xf libresprite.zip", "cd libresprite.app/Contents/MacOS", "./libresprite"],
        "posix" : []
      },
      "run" : {
        "nt" : ["libresprite.exe"],
        "darwin" : ["cd libresprite.app/Contents/MacOS", "./libresprite"],
        "posix" : null
      },
      "show" : [
        "Successfuly installed Libresprite!",
        "License - https://github.com/LibreSprite/LibreSprite/raw/refs/heads/stable-1.x/LICENSE.txt"
      ]
    }
  }
}
